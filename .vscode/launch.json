{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension (Auto Build)",
      "type": "extensionHost",
      "request": "launch",
      "trace": true,
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--folder-uri=${workspaceFolder}",
        "--disable-gpu",
        "--enable-logging",
        "--log-level=trace"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],
      "preLaunchTask": "npm: build"
    },
    {
      "name": "Run Extension (Manual Build, No Prelaunch Task)",
      "type": "extensionHost",
      "request": "launch",
      "trace": true,
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--folder-uri=${workspaceFolder}",
        "--disable-gpu",
        "--enable-logging",
        "--log-level=trace"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ]
    }
  ]
}

