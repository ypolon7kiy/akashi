{
  // Selecting text in the integrated terminal copies to the clipboard immediately.
  // On Linux, middle-click usually pastes the PRIMARY selection (from selecting anywhere);
  // this setting helps when an app only reads the regular clipboard.
  "terminal.integrated.copyOnSelection": true,

  // ESLint 9 + eslint.config.mjs (flat config): ensures the VS Code ESLint extension uses it.
  "eslint.useFlatConfig": true,
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact"]
}
