{
  "name": "akashi",
  "displayName": "Akashi",
  "description": "Akashi extension.",
  "version": "0.0.1",
  "publisher": "your-name-or-org",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:dddExample.example.showPanel",
    "onView:akashi.sidebar",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "akashi",
          "title": "Akashi",
          "icon": "media/akashi-activity.svg"
        }
      ]
    },
    "views": {
      "akashi": [
        {
          "type": "webview",
          "id": "akashi.sidebar",
          "name": "Sidebar"
        }
      ]
    },
    "commands": [
      {
        "command": "dddExample.example.showPanel",
        "title": "Akashi: Show Panel",
        "category": "Akashi"
      }
    ],
    "configuration": {
      "title": "Akashi",
      "properties": {
        "akashi.sources.presets": {
          "type": "array",
          "order": 10,
          "items": {
            "type": "string",
            "enum": [
              "claude",
              "cursor",
              "antigravity",
              "codex"
            ]
          },
          "default": [
            "claude",
            "cursor",
            "antigravity",
            "codex"
          ],
          "uniqueItems": true,
          "description": "Which tool families appear in the Source Index."
        },
        "akashi.sources.includeHomeConfig": {
          "type": "boolean",
          "order": 20,
          "default": true,
          "description": "Include user-home tool configs in the index."
        },
        "akashi.sources.claudeConfigDir": {
          "type": "string",
          "order": 30,
          "default": "",
          "description": "Claude user config dir. Absolute or ~/…. Empty: CLAUDE_CONFIG_DIR or ~/.claude."
        },
        "akashi.sources.codexHome": {
          "type": "string",
          "order": 40,
          "default": "",
          "description": "Codex user config dir. Absolute or ~/…. Empty: CODEX_HOME or ~/.codex."
        },
        "akashi.sources.cursorConfigDir": {
          "type": "string",
          "order": 50,
          "default": "",
          "description": "Cursor user config dir. Absolute or ~/…. Empty: ~/.cursor."
        },
        "akashi.sources.geminiConfigDir": {
          "type": "string",
          "order": 60,
          "default": "",
          "description": "Gemini user config dir. Absolute or ~/…. Empty: GEMINI_CONFIG_DIR or ~/.gemini."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"*.mjs\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"*.mjs\"",
    "fix": "npm run lint:fix && npm run format",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^15.0.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.15.0",
    "vitest": "^3.0.5",
    "vsce": "^2.15.0"
  }
}
