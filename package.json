{
  "name": "akashi",
  "displayName": "Akashi",
  "description": "Akashi extension.",
  "version": "0.0.1",
  "publisher": "yp",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:akashi.graph.showPanel",
    "onCommand:akashi.sources.refresh",
    "onView:akashi.sidebar",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "akashi",
          "title": "Akashi",
          "icon": "media/akashi-activity.svg"
        }
      ]
    },
    "views": {
      "akashi": [
        {
          "type": "webview",
          "id": "akashi.sidebar",
          "name": "Akashi"
        }
      ]
    },
    "commands": [
      {
        "command": "akashi.sources.refresh",
        "title": "Refresh source index",
        "category": "Akashi",
        "icon": "$(refresh)"
      },
      {
        "command": "akashi.graph.showPanel",
        "title": "Show 3D graph",
        "category": "Akashi",
        "icon": "$(graph-line)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "akashi.sources.refresh",
          "when": "view == akashi.sidebar",
          "group": "navigation@0"
        },
        {
          "command": "akashi.graph.showPanel",
          "when": "view == akashi.sidebar",
          "group": "navigation@1"
        }
      ]
    },
    "configuration": {
      "title": "Akashi",
      "properties": {
        "akashi.presets": {
          "type": "array",
          "order": 10,
          "items": {
            "type": "string",
            "enum": [
              "claude",
              "cursor",
              "antigravity",
              "codex"
            ]
          },
          "default": [
            "claude",
            "cursor",
            "antigravity",
            "codex"
          ],
          "uniqueItems": true,
          "description": "Which tool families appear in the Source Index."
        },
        "akashi.includeHomeConfig": {
          "type": "boolean",
          "order": 20,
          "default": true,
          "description": "Include user-home tool configs in the index."
        },
        "akashi.homePathOverrides": {
          "type": "object",
          "order": 30,
          "title": "Home path overrides",
          "description": "Optional user config directory per tool. Use absolute paths or ~/…. Empty values use environment variables (where supported) or defaults under the user home directory (e.g. ~/.claude, ~/.cursor).",
          "additionalProperties": false,
          "properties": {
            "claude": {
              "type": "string",
              "default": ""
            },
            "codex": {
              "type": "string",
              "default": ""
            },
            "cursor": {
              "type": "string",
              "default": ""
            },
            "gemini": {
              "type": "string",
              "default": ""
            }
          },
          "default": {
            "claude": "",
            "codex": "",
            "cursor": "",
            "gemini": ""
          }
        },
        "akashi.sidebar.fileColors": {
          "type": "object",
          "order": 70,
          "title": "File colors",
          "description": "Colors for source categories in the sidebar. Applied when the sidebar loads; reload the window (Developer: Reload Window) after changing values.",
          "markdownDescription": "Colors for source categories in the sidebar. Applied when the sidebar loads; reload the window (**Developer: Reload Window**) after changing values.",
          "additionalProperties": false,
          "properties": {
            "context": {
              "type": "string",
              "format": "color",
              "default": "#d18616"
            },
            "rule": {
              "type": "string",
              "format": "color",
              "default": "#d18616"
            },
            "skill": {
              "type": "string",
              "format": "color",
              "default": "#b180d7"
            },
            "hook": {
              "type": "string",
              "format": "color",
              "default": "#f14c4c"
            },
            "config": {
              "type": "string",
              "format": "color",
              "default": "#cca700"
            },
            "mcp": {
              "type": "string",
              "format": "color",
              "default": "#3794ff"
            },
            "unknown": {
              "type": "string",
              "format": "color",
              "default": "#cccccc"
            }
          },
          "default": {
            "context": "#d18616",
            "rule": "#d18616",
            "skill": "#b180d7",
            "hook": "#f14c4c",
            "config": "#cca700",
            "mcp": "#3794ff",
            "unknown": "#cccccc"
          }
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"*.mjs\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"*.mjs\"",
    "fix": "npm run lint:fix && npm run format",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@vscode/codicons": "^0.0.45",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.158.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.158.3",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^15.0.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.15.0",
    "vitest": "^3.0.5",
    "vsce": "^2.15.0"
  }
}
